DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/chandigarh_bakery

NEXT_PUBLIC_APP_NAME=Chandigarh Bakery
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080
NEXT_PUBLIC_ADMIN_URL=http://localhost:8000

JWT_ACCESS_SECRET=replace_with_long_random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=no-reply@example.com
LOG_DEV_OTPS=false
